FROM python:3.11-slim

WORKDIR /app
COPY backend/05_INTAKE/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ /app/backend/

# .env not needed on Railway — env vars are set in the dashboard.
# For local Docker builds, mount or copy .env.
COPY .env* /app/

CMD ["python", "backend/05_INTAKE/pipeline_worker.py", "--poll", "10"]
